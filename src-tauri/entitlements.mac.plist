<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Full Disk Access: required to open /dev/rdiskN for APFS/HFS+ parsing (P2-T01, P2-T02) -->
    <!-- Distribution: notarised DMG direct download only (DECISION-003). Not App Store. -->
    <!-- Apple entitlement reference: com.apple.security.files.all -->
    <key>com.apple.security.files.all</key>
    <true/>

    <!-- App Sandbox MUST be false: sandboxed apps cannot open raw disk devices -->
    <!-- Reference: Apple TN3107 — raw disk access requires sandbox disabled -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Hardened Runtime is required for notarisation; sandbox=false is compatible with it -->
    <!-- The combination (hardened runtime + no sandbox + FDA) is the standard pattern for -->
    <!-- disk utility apps distributed outside the App Store. -->
</dict>
</plist>
