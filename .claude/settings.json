{
	"env": {
		"CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
	},
	"permissions": {
		"defaultMode": "acceptEdits",
		"disableBypassPermissionsMode": "disable",
		"allow": [
			"Bash(cargo:*)",
			"Bash(npm:*)",
			"Bash(npx:*)",
			"Bash(make:*)",
			"Bash(git:*)",
			"Bash(cat:*)",
			"Bash(ls:*)",
			"Bash(find:*)",
			"Bash(grep:*)",
			"Bash(mkdir:*)",
			"Bash(cp:*)",
			"Bash(mv:*)",
			"Bash(touch:*)",
			"Bash(echo:*)",
			"Bash(rustfmt:*)",
			"Bash(cargo-llvm-cov:*)",
			"Read(*)",
			"Write(*)"
		],
		"deny": [
			"Bash(curl:*)",
			"Bash(wget:*)",
			"Bash(ssh:*)",
			"Bash(scp:*)",
			"Bash(nc:*)",
			"Bash(ncat:*)"
		]
	}
}
