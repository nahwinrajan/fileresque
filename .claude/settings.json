{
	"env": {
		"CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
	},
	"permissions": {
		"defaultMode": "acceptEdits",
		"disableBypassPermissionsMode": "disable",
		"allow": [
			"Bash(cargo:*)",
			"Bash(bun:*)",
			"Bash(make:*)",
			"Bash(git:*)",
			"Bash(rustfmt:*)",
			"Bash(cargo-llvm-cov:*)",
			"Bash(cat:*)",
			"Bash(ls:*)",
			"Bash(find:*)",
			"Bash(grep:*)",
			"Bash(rg:*)",
			"Bash(head:*)",
			"Bash(tail:*)",
			"Bash(wc:*)",
			"Bash(sort:*)",
			"Bash(uniq:*)",
			"Bash(diff:*)",
			"Bash(cut:*)",
			"Bash(tr:*)",
			"Bash(column:*)",
			"Bash(file:*)",
			"Bash(jq:*)",
			"Bash(tree:*)",
			"Bash(which:*)",
			"Bash(lsof:*)",
			"Bash(sw_vers:*)",
			"Bash(mkdir:*)",
			"Bash(cp:*)",
			"Bash(mv:*)",
			"Bash(touch:*)",
			"Bash(echo:*)",
			"Read(*)",
			"Write(//Users/nahwinrajan/Developer/rust/fileresque/**)",
			"Write(//private/tmp/claude-501/**)",
			"Write(//Users/nahwinrajan/.claude/projects/**)"
		],
		"deny": [
			"Bash(curl:*)",
			"Bash(wget:*)",
			"Bash(ssh:*)",
			"Bash(scp:*)",
			"Bash(nc:*)",
			"Bash(ncat:*)",
			"Bash(make dev:*)",
			"Bash(make build:*)",
			"Bash(bun tauri dev:*)",
			"Bash(bun tauri build:*)",
			"Bash(bun dev:*)",
			"Bash(bunx vite:*)",
			"Bash(vite:*)",
			"Bash(cargo run:*)",
			"Bash(./target/debug/fileresque:*)",
			"Bash(//Users/nahwinrajan/Developer/rust/fileresque/target/debug/fileresque:*)",
			"Bash(diskutil:*)",
			"Bash(dd:*)",
			"Bash(sudo:*)",
			"Bash(kill:*)",
			"Bash(rm:*)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{ "type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-disk.py\"" }
				]
			}
		]
  	}
}
