/**
 * FileResque — Design Tokens
 * Source of truth for all CSS custom properties.
 * Generated by: Designer Agent (🟣)
 * Reference: docs/design/design-brief.md
 *
 * Import order in app root:
 *   1. tokens.css  (this file — defines all --vars)
 *   2. reset.css   (box-sizing, margin reset)
 *   3. typography.css (font-face declarations)
 *   4. app.css     (global layout, body, scrollbar)
 *
 * Theme architecture:
 *   :root             → dark theme (hero default)
 *   .theme-light,
 *   @media (prefers-color-scheme: light) → light theme overrides
 *
 * Audit note (v1.1): corrected against designer.md agent definition.
 * Changes from v1.0: --color-bg-base = #0a0e17 (was #0d1220, now --color-bg-layer);
 * --color-shadow-light = #1d273d (was #1d2739); --color-text-secondary = #8a94a6
 * (was #c8cfd9, now --color-text-dim); focus ring = #ffc800 / offset = 2px (was blue/3px);
 * --radius-sm/md/lg = 4/8/12px (was 6/10/16px); added --shadow-outset/--shadow-inset
 * canonical aliases; added --font-family.
 */

/* ============================================================
   DARK THEME — DEFAULT (Firmament Blue)
   ============================================================ */

:root {
  /* ----------------------------------------------------------
     COLOR — Surfaces (Firmament Stack)
     Light source: top-left (315° / NW)
  ---------------------------------------------------------- */

  /** Window chrome border — deepest void */
  --color-bg-void:       #070912;
  /** App shell background — canonical per agent-def Design Token Format */
  --color-bg-base:       #0a0e17;
  /** Intermediate layer — panel and content area background */
  --color-bg-layer:      #0d1220;
  /** Primary panel and card surface — neumorphic base */
  --color-bg-surface:    #121826;
  /** Raised within surface (inputs, nested cards, table headers) */
  --color-bg-surface-2:  #171e2e;
  /** Highly raised (dropdown menus, tooltips) */
  --color-bg-surface-3:  #1d2740;
  /** Active/hover highlight layer on raised elements */
  --color-bg-surface-4:  #253352;

  /* ----------------------------------------------------------
     COLOR — Neumorphic Shadow Pair
     Derived from --color-bg-surface (#121826)
     Dark:  approx −30% luminance, maintains blue undertone
     Light: approx +40% luminance, blue-shifted highlight
  ---------------------------------------------------------- */

  --color-shadow-dark:   #07090f;
  --color-shadow-light:  #1d273d;

  /* ----------------------------------------------------------
     COLOR — Cyber Accents
  ---------------------------------------------------------- */

  /** Mechanic Blue — primary safe action, links, selection */
  --color-accent-primary:   #0084ff;
  /** Softer informational blue — tooltips, data labels */
  --color-accent-info:      #58a6ff;
  /** Secondary accent — probability sparklines, audit markers */
  --color-accent-alt:       #9b59ff;

  /* ----------------------------------------------------------
     COLOR — Semantic Status
     Maps to: ProbabilityTier, recovery outcomes, system states
  ---------------------------------------------------------- */

  /** High probability / successfully recovered */
  --color-success:          #3fb950;
  /** Construction Yellow — hardware warning, Medium probability */
  --color-warning:          #ffc800;
  /** Danger Red — unrecoverable, critical error, destructive */
  --color-danger:           #e5534b;
  /** Info — same as accent-info, aliased for semantic clarity */
  --color-info:             #58a6ff;

  /* ----------------------------------------------------------
     COLOR — Text Stack
     --color-text-secondary: #8a94a6 is the canonical value per agent-def.
     --color-text-dim: #c8cfd9 is a supplementary brighter mid-tone
     (additive, not in agent-def) for sub-headings and prominent metadata.
  ---------------------------------------------------------- */

  /** Headlines, file names, primary UI labels */
  --color-text-primary:    #f9f8f6;
  /** Bright mid-tone — sub-headings, prominent metadata (supplementary) */
  --color-text-dim:        #c8cfd9;
  /** Supporting text, labels, timestamps — canonical per agent-def */
  --color-text-secondary:  #8a94a6;
  /** Explicitly disabled states only — intentionally low contrast */
  --color-text-disabled:   #4a5466;
  /** Text on warning/attention coloured surfaces */
  --color-text-on-warning: #1a1200;
  /** Text on filled primary button (14px/600 minimum — see design brief) */
  --color-text-on-accent:  #ffffff;

  /* ----------------------------------------------------------
     COLOR — Interactive State Overlays
     Applied as background-color or border-color additions
  ---------------------------------------------------------- */

  --color-hover-overlay:    rgba(255, 255, 255, 0.04);
  --color-active-overlay:   rgba(255, 255, 255, 0.08);
  /**
   * Construction Yellow (#ffc800) per agent-def Component Spec Format:
   * "Focus ring: outline: 2px solid var(--color-warning); outline-offset: 2px"
   * Yields 9.8:1 contrast on dark surface — superior to blue (4.65:1).
   * Light theme overrides this to #0050b3 (yellow fails on light bg — only 1.3:1).
   */
  --color-focus-ring:       #ffc800;
  --color-selection-bg:     rgba(0, 132, 255, 0.15);

  /* ----------------------------------------------------------
     COLOR — Border & Divider
  ---------------------------------------------------------- */

  /** Hairline divider between sections */
  --color-border-subtle:    rgba(255, 255, 255, 0.06);
  /** Standard component border (inputs, cards in focus) */
  --color-border-default:   rgba(255, 255, 255, 0.10);
  /** Accent border (focused input, selected card) */
  --color-border-accent:    #0084ff;
  /** Danger border (error input) */
  --color-border-danger:    #e5534b;
  /** Success border (confirmed recovery destination) */
  --color-border-success:   #3fb950;

  /* ----------------------------------------------------------
     COLOR — Probability Tier (maps to ProbabilityTier enum)
  ---------------------------------------------------------- */

  --color-tier-high:        #3fb950;
  --color-tier-high-bg:     rgba(63, 185, 80, 0.12);
  --color-tier-medium:      #ffc800;
  --color-tier-medium-bg:   rgba(255, 200, 0, 0.12);
  --color-tier-low:         #e5534b;
  --color-tier-low-bg:      rgba(229, 83, 75, 0.12);
  --color-tier-unknown:     #8a94a6;
  --color-tier-unknown-bg:  rgba(138, 148, 166, 0.10);

  /* ----------------------------------------------------------
     TYPOGRAPHY — Font Families
  ---------------------------------------------------------- */

  /**
   * Canonical font family token — matches agent-def Design Token Format.
   * Component specs reference --font-family for UI text.
   */
  --font-family:
    'Inter',
    system-ui,
    -apple-system,
    sans-serif;

  /**
   * Extended alias with richer fallback chain — use in global body rule.
   * Component specs may also reference --font-sans interchangeably.
   */
  --font-sans:
    'Inter',
    -apple-system,
    BlinkMacSystemFont,
    'Segoe UI',
    system-ui,
    sans-serif;

  /**
   * Monospace: JetBrains Mono (bundled subset — ASCII + Latin Ext A)
   * Used for ALL data from disk: names, paths, sizes, inodes, addresses.
   * Canonical token name per agent-def Design Token Format.
   */
  --font-mono:
    'JetBrains Mono',
    'SF Mono',
    'Menlo',
    'Cascadia Code',
    'Consolas',
    monospace;

  /* ----------------------------------------------------------
     TYPOGRAPHY — Scale (14px base)
  ---------------------------------------------------------- */

  --font-size-2xs:  0.625rem;   /* 10px — badge labels, extreme metadata */
  --font-size-xs:   0.6875rem;  /* 11px — table col headers, secondary mono */
  --font-size-sm:   0.75rem;    /* 12px — table cells, paths, secondary labels */
  --font-size-md:   0.875rem;   /* 14px — body default, button text */
  --font-size-lg:   1rem;       /* 16px — card titles, modal body */
  --font-size-xl:   1.25rem;    /* 20px — section headings */
  --font-size-2xl:  1.5rem;     /* 24px — page headings */
  --font-size-3xl:  2rem;       /* 32px — splash/onboarding hero */

  /* ----------------------------------------------------------
     TYPOGRAPHY — Weights
  ---------------------------------------------------------- */

  --font-weight-regular:    400;
  --font-weight-medium:     500;
  --font-weight-semibold:   600;
  --font-weight-bold:       700;

  /* ----------------------------------------------------------
     TYPOGRAPHY — Line Heights
  ---------------------------------------------------------- */

  --line-height-none:     1;      /* single-line chips, badges */
  --line-height-tight:    1.2;    /* headings */
  --line-height-snug:     1.35;   /* mono data rows, dense tables */
  --line-height-base:     1.5;    /* body text */
  --line-height-relaxed:  1.75;   /* help text, descriptions */

  /* ----------------------------------------------------------
     TYPOGRAPHY — Letter Spacing
  ---------------------------------------------------------- */

  --tracking-tight:   -0.01em;
  --tracking-normal:   0em;
  --tracking-wide:    +0.04em;  /* uppercase labels, column headers */
  --tracking-wider:   +0.08em;  /* all-caps badge text */

  /* ----------------------------------------------------------
     SPACING (4px base grid)
     All component padding/margin must be a multiple of 4px.
  ---------------------------------------------------------- */

  --space-px:    1px;
  --space-0-5:   0.125rem;   /* 2px */
  --space-1:     0.25rem;    /* 4px */
  --space-2:     0.5rem;     /* 8px */
  --space-3:     0.75rem;    /* 12px */
  --space-4:     1rem;       /* 16px */
  --space-5:     1.25rem;    /* 20px */
  --space-6:     1.5rem;     /* 24px */
  --space-8:     2rem;       /* 32px */
  --space-10:    2.5rem;     /* 40px */
  --space-12:    3rem;       /* 48px */
  --space-16:    4rem;       /* 64px */
  --space-20:    5rem;       /* 80px */
  --space-24:    6rem;       /* 96px */

  /* ----------------------------------------------------------
     BORDER RADIUS
     sm/md/lg/pill values are canonical per agent-def Design Token Format.
     xs and xl are additive extensions.
  ---------------------------------------------------------- */

  --radius-none:  0px;
  --radius-xs:    2px;    /* micro chips, hairline rounding (additive) */
  --radius-sm:    4px;    /* chips, badges, small indicators — per agent-def */
  --radius-md:    8px;    /* standard buttons, cards, panels — per agent-def */
  --radius-lg:    12px;   /* large panels, modals — per agent-def */
  --radius-xl:    20px;   /* hero cards, onboarding surfaces (additive) */
  --radius-pill:  9999px; /* pill badges, toggles — per agent-def */

  /* ----------------------------------------------------------
     ELEVATION — Neumorphic Shadow Compounds
     Compose from --color-shadow-dark + --color-shadow-light.
     Override the pair per theme; these compounds update automatically.

     CANONICAL NAMES: --shadow-outset and --shadow-inset are the
     authoritative tokens per agent-def. GSAP button animations call
     var(--shadow-inset) and var(--shadow-outset) directly. The
     levelled variants (raised-sm/md/lg, inset-sm/md) are available
     for components that need more or less depth than the standard.
  ---------------------------------------------------------- */

  /**
   * Canonical outset shadow — per agent-def Design Token Format.
   * Default resting state for all raised interactive elements.
   * GSAP press animation: animates FROM this TO --shadow-inset.
   */
  --shadow-outset:
    4px 4px 10px var(--color-shadow-dark),
    -4px -4px 10px var(--color-shadow-light);

  /**
   * Canonical inset shadow — per agent-def Design Token Format.
   * Active/pressed state. GSAP press animation targets this value.
   */
  --shadow-inset:
    inset 4px 4px 10px var(--color-shadow-dark),
    inset -4px -4px 10px var(--color-shadow-light);

  /** Subtle lift: table row hover, nested card hover */
  --shadow-raised-sm:
    6px 6px 12px var(--color-shadow-dark),
    -6px -6px 12px var(--color-shadow-light);

  /** Standard raised: buttons, cards, panels — additive, equals --shadow-outset depth */
  --shadow-raised-md:
    8px 8px 18px var(--color-shadow-dark),
    -8px -8px 18px var(--color-shadow-light);

  /** Deep raised: modals, floating dropdowns, tooltips */
  --shadow-raised-lg:
    12px 12px 28px var(--color-shadow-dark),
    -12px -12px 28px var(--color-shadow-light);

  /** Subtle depression: selected row, active tab */
  --shadow-inset-sm:
    inset 3px 3px 6px var(--color-shadow-dark),
    inset -3px -3px 6px var(--color-shadow-light);

  /** Deep depression: active/focused input, pressed card */
  --shadow-inset-md:
    inset 5px 5px 12px var(--color-shadow-dark),
    inset -5px -5px 12px var(--color-shadow-light);

  /** Flat: no shadow — flush with background, table rows at rest */
  --shadow-flat: none;

  /* ----------------------------------------------------------
     Z-INDEX STACK
  ---------------------------------------------------------- */

  --z-base:      0;
  --z-raised:    10;
  --z-dropdown:  100;
  --z-overlay:   200;
  --z-toast:     300;
  --z-tooltip:   400;

  /* ----------------------------------------------------------
     MOTION — Durations
  ---------------------------------------------------------- */

  --duration-instant:   0ms;
  --duration-fastest:   80ms;   /* micro: icon swap, badge colour */
  --duration-fast:      140ms;  /* button press, row hover */
  --duration-base:      240ms;  /* panel reveal, modal appear */
  --duration-slow:      400ms;  /* page transitions, onboarding */
  --duration-crawl:     800ms;  /* progress bar smooth-fill */

  /* ----------------------------------------------------------
     MOTION — Easing Curves
  ---------------------------------------------------------- */

  /**
   * Spring with slight overshoot — tactile "pop"
   * Used for: button release, card hover lift, modal entrance
   */
  --ease-spring:     cubic-bezier(0.34, 1.56, 0.64, 1);

  /**
   * Material standard — smooth, no overshoot
   * Used for: colour transitions, badge updates, progress fill
   */
  --ease-snappy:     cubic-bezier(0.4, 0, 0.2, 1);

  /**
   * Heavy press-in — slow start, abrupt end
   * Used exclusively for button active/press state
   */
  --ease-depress:    cubic-bezier(0.36, 0.07, 0.19, 0.97);

  /**
   * Clean exit — used for dismiss/remove animations
   */
  --ease-out-cubic:  cubic-bezier(0.33, 1, 0.68, 1);

  /* ----------------------------------------------------------
     LAYOUT — App Shell Dimensions
  ---------------------------------------------------------- */

  --titlebar-height:     36px;
  --statusbar-height:    28px;
  --sidebar-width:       220px;
  --sidebar-width-min:   56px;   /* icon-only collapsed state */
  --content-max-width:   1280px;

  /* ----------------------------------------------------------
     MISC — Focus Ring
     Per agent-def Component Spec Format:
     "Focus ring: outline: 2px solid var(--color-warning); outline-offset: 2px"
     Construction Yellow achieves 9.8:1 on dark surface.
     Light theme overrides --color-focus-ring to deep blue (#0050b3, 6.3:1 on light bg).
  ---------------------------------------------------------- */

  --focus-ring-width:   2px;
  --focus-ring-offset:  2px;
  --focus-ring-color:   var(--color-focus-ring);
}


/* ============================================================
   LIGHT THEME
   Applied via: @media prefers-color-scheme: light
   OR explicitly via: <html class="theme-light">
   ============================================================ */

@media (prefers-color-scheme: light) {
  :root {
    /* Surface stack */
    --color-bg-void:       #c4c8d4;
    --color-bg-base:       #d0d4de;
    --color-bg-layer:      #dce0ea;
    --color-bg-surface:    #e8ecf4;   /* neumorphic base — light theme */
    --color-bg-surface-2:  #eef2f8;
    --color-bg-surface-3:  #f4f7fb;
    --color-bg-surface-4:  #ffffff;

    /* Shadow pair — light neumorphism */
    --color-shadow-dark:   #b8bcc8;
    --color-shadow-light:  #ffffff;

    /* Text stack */
    --color-text-primary:    #1a2030;
    --color-text-dim:        #3a4560;
    --color-text-secondary:  #6a7590;
    --color-text-disabled:   #a0aabb;
    --color-text-on-warning: #1a1200;
    --color-text-on-accent:  #ffffff;

    /**
     * Focus ring override — Construction Yellow (#ffc800) achieves only 1.3:1
     * contrast on the light surface (#e8ecf4). Override to deep blue which
     * achieves 6.3:1 on light bg while remaining accessible.
     */
    --color-focus-ring:    #0050b3;

    /* Borders */
    --color-border-subtle:   rgba(0, 0, 0, 0.06);
    --color-border-default:  rgba(0, 0, 0, 0.12);

    /* Overlays */
    --color-hover-overlay:   rgba(0, 0, 0, 0.04);
    --color-active-overlay:  rgba(0, 0, 0, 0.08);
    --color-selection-bg:    rgba(0, 132, 255, 0.12);

    /* Tier backgrounds — slightly less saturated on light */
    --color-tier-high-bg:    rgba(63, 185, 80, 0.10);
    --color-tier-medium-bg:  rgba(255, 200, 0, 0.10);
    --color-tier-low-bg:     rgba(229, 83, 75, 0.10);
    --color-tier-unknown-bg: rgba(100, 110, 130, 0.08);

    /* Accent colours stay the same — they are theme-invariant */
    /* --color-accent-primary, --color-warning, etc. unchanged */
  }
}

/* Explicit class override — allows app to force theme regardless of system pref */
.theme-light {
  /* Same overrides as @media block above */
  --color-bg-void:       #c4c8d4;
  --color-bg-base:       #d0d4de;
  --color-bg-layer:      #dce0ea;
  --color-bg-surface:    #e8ecf4;
  --color-bg-surface-2:  #eef2f8;
  --color-bg-surface-3:  #f4f7fb;
  --color-bg-surface-4:  #ffffff;
  --color-shadow-dark:   #b8bcc8;
  --color-shadow-light:  #ffffff;
  --color-text-primary:    #1a2030;
  --color-text-dim:        #3a4560;
  --color-text-secondary:  #6a7590;
  --color-text-disabled:   #a0aabb;
  --color-focus-ring:      #0050b3;
  --color-border-subtle:   rgba(0, 0, 0, 0.06);
  --color-border-default:  rgba(0, 0, 0, 0.12);
  --color-hover-overlay:   rgba(0, 0, 0, 0.04);
  --color-active-overlay:  rgba(0, 0, 0, 0.08);
  --color-selection-bg:    rgba(0, 132, 255, 0.12);
}

.theme-dark {
  /* Explicit dark class — no-op since :root is already dark, but useful for
     forcing dark mode on a light-OS system via user preference toggle */
  /* All :root values already applied — nothing to override */
}


/* ============================================================
   GLOBAL INTERACTION BASELINE
   Applied here so all components inherit without repetition.
   ============================================================ */

/**
 * Universal focus ring — mandatory for keyboard navigation.
 * Neumorphism provides no visible boundary; the focus ring is
 * the only reliable interactive-state indicator for keyboard users.
 * Construction Yellow (#ffc800) on dark: 9.8:1 contrast.
 * Deep blue (#0050b3) on light: 6.3:1 contrast (overridden per theme above).
 */
:focus-visible {
  outline: var(--focus-ring-width) solid var(--focus-ring-color);
  outline-offset: var(--focus-ring-offset);
  border-radius: var(--radius-sm);
}

/**
 * Respect reduced motion — collapse all durations.
 * GSAP components must also check matchMedia in their JS.
 */
@media (prefers-reduced-motion: reduce) {
  :root {
    --duration-fastest: 0ms;
    --duration-fast:    0ms;
    --duration-base:    0ms;
    --duration-slow:    0ms;
    --duration-crawl:   0ms;
    --ease-spring:      linear;
    --ease-snappy:      linear;
    --ease-depress:     linear;
    --ease-out-cubic:   linear;
  }
}

/**
 * Scan activity shimmer — atmospheric surface animation.
 * Applied to .scanning class on the active scan panel.
 * @media prefers-reduced-motion collapses duration to 0ms above,
 * which effectively stops this animation.
 */
@keyframes scan-sweep {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

.scanning {
  background-image: linear-gradient(
    90deg,
    transparent 0%,
    rgba(0, 132, 255, 0.04) 50%,
    transparent 100%
  );
  background-size: 200% 100%;
  animation: scan-sweep 3s linear infinite;
}
